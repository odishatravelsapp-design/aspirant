    {
      "id": "osssc-q-0001",
      "section": "Arithmetic",
      "topic": "Percentage",
      "difficulty": "easy",
      "year": 2021,
      "source": "pyq",
      "question": "A man spends 75% of his income and saves Rs. 1500. What is his income?",
      "options": [
        "Rs. 4500",
        "Rs. 6000",
        "Rs. 5000",
        "Rs. 7500"
      ],
      "answer": 1,
      "explanation": "He saves 25% of income = 1500. So income = 1500 / 0.25 = Rs. 6000.",
      "translations": {
        "or": {
          "question": "ଜଣେ ବ୍ୟକ୍ତି ତାଙ୍କ ଆୟର 75% ଖର୍ଚ୍ଚ କରନ୍ତି ଏବଂ 1500 ଟଙ୍କା ସଞ୍ଚୟ କରନ୍ତି। ତାଙ୍କ ଆୟ କେତେ?",
          "options": [
            "4500 ଟଙ୍କା",
            "6000 ଟଙ୍କା",
            "5000 ଟଙ୍କା",
            "7500 ଟଙ୍କା"
          ],
          "explanation": "ସେ ଆୟର 25% ସଞ୍ଚୟ କରନ୍ତି = 1500। ତେଣୁ ଆୟ = 1500 / 0.25 = 6000 ଟଙ୍କା।"
        }
      }
    },
